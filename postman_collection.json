{
	"info": {
		"_postman_id": "admin-event-bumigora-api",
		"name": "Sistem Informasi Pendidikan & Event Akademik",
		"description": "API Collection untuk Sistem Informasi Pendidikan & Event Akademik (Backend Laravel)\n\n## Authentication\n- Semua endpoint kecuali login & register memerlukan header:\n  `Authorization: Bearer {token}`\n\n## Roles\n- mahasiswa: Lihat event, informasi, notifikasi\n- dosen: CRUD event\n- admin: CRUD semua data + manajemen user\n\n## Sample Users (after seeding)\n- Admin: admin@example.com / password\n- Dosen: dosen@example.com / password  \n- Mahasiswa: mahasiswa@example.com / password",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "AUTHENTICATION",
			"item": [
				{
					"name": "Register User",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"nama\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"password\",\n    \"password_confirmation\": \"password\",\n    \"role\": \"mahasiswa\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{BASE_URL}}/api/register",
							"host": ["{{BASE_URL}}"],
							"path": ["api", "register"]
						},
						"description": "Register user baru. Role: mahasiswa, dosen, atau admin"
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.token) {",
									"    pm.collectionVariables.set('auth_token', jsonData.data.token);",
									"    pm.collectionVariables.set('user_role', jsonData.data.user.role);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"mahasiswa@example.com\",\n    \"password\": \"password\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{BASE_URL}}/api/login",
							"host": ["{{BASE_URL}}"],
							"path": ["api", "login"]
						},
						"description": "Login user. Response includes token yang perlu disimpan untuk request berikutnya."
					},
					"response": []
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}"
							}
						],
						"url": {
							"raw": "{{BASE_URL}}/api/logout",
							"host": ["{{BASE_URL}}"],
							"path": ["api", "logout"]
						},
						"description": "Logout user (invalidate token)"
					},
					"response": []
				},
				{
					"name": "Get Current User",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{auth_token}}",
									"isSecret": false
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BASE_URL}}/api/me",
							"host": ["{{BASE_URL}}"],
							"path": ["api", "me"]
						},
						"description": "Ambil data user yang sedang login"
					},
					"response": []
				}
			]
